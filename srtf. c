#include <stdio.h>
#include <string.h>
int main() {
    int n, i, time = 0, completed = 0, min;
    int at[20], bt[20], rt[20], wt[20], tat[20], finish;
    char pid[20][5];
    float avg_wt = 0, avg_tat = 0;
    printf("Enter number of processes: ");
    scanf("%d", &n);
    for (i = 0; i < n; i++) {
        printf("Enter Process ID, Arrival Time, Burst Time: ");
        scanf("%s %d %d", pid[i], &at[i], &bt[i]);
        rt[i] = bt[i];
    }
    while (completed < n) {
        min = -1;

        for (i = 0; i < n; i++) {
            if (at[i] <= time && rt[i] > 0) {
                if (min == -1 || rt[i] < rt[min]) {
                    min = i;
                }
            }
        }

        if (min == -1) {
            time++;
            continue;
        }

        rt[min]--;
        time++;

        if (rt[min] == 0) {
            completed++;
            finish = time;

            tat[min] = finish - at[min];
            wt[min] = tat[min] - bt[min];

            avg_wt += wt[min];
            avg_tat += tat[min];
        }
    }

    printf("\nWaiting Time:\n");
    for (i = 0; i < n; i++) {
        printf("%s %d\n", pid[i], wt[i]);
    }

    printf("\nTurnaround Time:\n");
    for (i = 0; i < n; i++) {
        printf("%s %d\n", pid[i], tat[i]);
    }

    printf("\nAverage Waiting Time: %.1f", avg_wt / n);
    printf("\nAverage Turnaround Time: %.1f\n", avg_tat / n);

    return 0;
}
